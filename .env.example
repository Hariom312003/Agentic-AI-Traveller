# ============================================================================
# AI Traveller — environment configuration example
# Copy this file to `.env` and fill in the keys you have. The system degrades
# gracefully: it only routes to providers whose keys are present, and the
# rule-based fallback planner keeps the app usable with ZERO keys configured.
# ============================================================================

# ---- LLM providers (configure at least one for AI-generated plans) --------
# Priority order is controlled by LLM_PROVIDER_PRIORITY below, not by the
# order keys appear here.
GEMINI_API_KEY=
GEMINI_API_KEY_BACKUP=
GROQ_API_KEY=
GROQ_API_KEY_BACKUP=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Comma separated, first available+healthy provider wins. Valid tokens:
# gemini, gemini_backup, groq, groq_backup, openrouter, openai, anthropic
LLM_PROVIDER_PRIORITY=gemini,groq,openrouter,gemini_backup,groq_backup,openai,anthropic

# Model overrides (leave blank to use the built-in defaults in src/config.py)
GEMINI_MODEL=gemini-flash-lite-latest
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-sonnet-5

# ---- Embeddings -------------------------------------------------------------
# "gemini" = production-quality semantic embeddings (needs GEMINI_API_KEY + network).
# "local"  = deterministic, offline, zero-download hashing embedder. Used
#            automatically if the chosen provider has no key or fails.
EMBEDDING_PROVIDER=local

# ---- Circuit breaker / failover tuning --------------------------------------
CIRCUIT_FAILURE_THRESHOLD=3
CIRCUIT_RECOVERY_SECONDS=60
LLM_MAX_RETRIES_PER_PROVIDER=2
LLM_TIMEOUT_SECONDS=45

# ---- Storage ------------------------------------------------------------
CHROMA_DB_PATH=./chroma_db
MEMORY_DB_PATH=./data/memory.db
CHECKPOINT_DB_PATH=./data/checkpoints.sqlite

# ---- API ------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8010
API_BASE_URL=http://localhost:8010
CORS_ORIGINS=http://localhost:8501,http://localhost:8010

# ---- Misc -------------------------------------------------------------------
LOG_LEVEL=INFO
ENVIRONMENT=development
ANONYMIZED_TELEMETRY=False
DEFAULT_CURRENCY=INR
